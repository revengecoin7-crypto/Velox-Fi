modules = ["nodejs-24"]

[workflows]
runButton = "VeloxFi"

[[workflows.workflow]]
name = "VeloxFi"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && pnpm --filter @workspace/veloxfi run dev -- --host 0.0.0.0 --port 5173"
waitForPort = 5173

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "pnpm install && pnpm --filter @workspace/veloxfi run build"]
run = ["sh", "-c", "pnpm --filter @workspace/veloxfi run serve"]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_HELIUS_RPC_URL = "https://mainnet.helius-rpc.com/?api-key=f85d3d41-9efd-40e5-846b-56f43fc8e98a"
RESEND_API_KEY = "re_WKFsCLPb_6fVDmLZ9uuaE5wu1TfLog2Up"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 24044
externalPort = 80
